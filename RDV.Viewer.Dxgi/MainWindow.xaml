<Window x:Class="RDV.Viewer.Dxgi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RDV Viewer (DXGI)" Height="480" Width="640"
        MinHeight="400" MinWidth="500"
        Background="#1e1e1e"
        Closing="Window_Closing">

    <Grid>
        <Grid x:Name="ConnectPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Remote Desktop Viewer (DXGI)" FontSize="22" FontWeight="Light"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <TextBlock Grid.Row="1" Text="Host Address" Foreground="#aaaaaa" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" x:Name="HostBox" Margin="0,0,0,12"
                     TextChanged="HostBox_TextChanged"/>

            <TextBlock Grid.Row="3" Text="Port" Foreground="#aaaaaa" Margin="0,0,0,4"/>
            <TextBox Grid.Row="4" x:Name="PortBox" Text="8766" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="5" Text="Password" Foreground="#aaaaaa" Margin="0,0,0,4"/>
            <PasswordBox Grid.Row="6" x:Name="PasswordBox" Margin="0,0,0,20"
                         KeyDown="PasswordBox_KeyDown"/>

            <TextBlock Grid.Row="7" x:Name="ErrorLabel" Foreground="#ff6b6b"
                       TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

            <Button Grid.Row="8" x:Name="ConnectBtn" Content="Connect"
                    FontSize="14" Height="36" Click="ConnectBtn_Click"/>
        </Grid>

        <Grid x:Name="DesktopPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2a2a2a" Padding="6,4">
                <Grid>
                    <Border x:Name="MonitorBarContainer" HorizontalAlignment="Left"
                            Background="#44000000" CornerRadius="4" Padding="4,2"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" x:Name="MonitorBar"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Task Mgr" Padding="8,3" FontSize="12" Margin="0,0,4,0"
                                Background="#555" ToolTip="Send Ctrl+Shift+Esc to remote"
                                Click="KeyTaskMgr_Click"/>
                        <Button Content="Win+D" Padding="8,3" FontSize="12" Margin="0,0,4,0"
                                Background="#555" ToolTip="Send Win+D to remote"
                                Click="KeyWinD_Click"/>
                        <Button Content="Win+R" Padding="8,3" FontSize="12" Margin="0,0,4,0"
                                Background="#555" ToolTip="Send Win+R (Run dialog) to remote"
                                Click="KeyWinR_Click"/>
                        <Button Content="Ctrl+Alt+Del" Padding="8,3" FontSize="12" Margin="0,0,4,0"
                                Background="#555" ToolTip="Send Secure Attention Sequence to remote"
                                Click="KeySas_Click"/>
                        <Button Content="Run as Admin..." Padding="8,3" FontSize="12" Margin="0,0,4,0"
                                Background="#226622" ToolTip="Run a command on the remote PC with admin privileges (no UAC)"
                                Click="RunAsAdmin_Click"/>
                        <Button Content="Restart PC" Padding="8,3" FontSize="12" Margin="0,0,12,0"
                                Background="#884400" ToolTip="Send restart command to remote PC"
                                Click="RestartPC_Click"/>
                        <TextBlock x:Name="ConnectionStatusLabel" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="ResolutionLabel" Foreground="#aaa" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Disconnect" Padding="8,3" FontSize="12"
                                Background="#cc3333" Click="DisconnectBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Image Grid.Row="1" x:Name="DesktopImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   MouseMove="Desktop_MouseMove"
                   MouseDown="Desktop_MouseDown"
                   MouseUp="Desktop_MouseUp"
                   MouseWheel="Desktop_MouseWheel"
                   Cursor="Cross"/>
        </Grid>
    </Grid>
</Window>
